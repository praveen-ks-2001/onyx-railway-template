{
  "$schema": "https://schema.up.railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "/usr/local/bin/railway-entrypoint.sh /usr/share/opensearch/opensearch-docker-entrypoint.sh opensearch",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
